---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { SPECIALTIES } from '../lib/specialties';

const allArticles = await getCollection('artikel', ({ data }) => !data.draft);

const counts = new Map<string, number>();
for (const a of allArticles) {
  counts.set(a.data.category, (counts.get(a.data.category) || 0) + 1);
}

// Reihenfolge: zuerst Fachgebiete mit Artikeln (nach Anzahl absteigend),
// dann der Rest alphabetisch
const withCount = SPECIALTIES.map((s) => ({ ...s, count: counts.get(s.name) || 0 }));
withCount.sort((a, b) => {
  if ((a.count > 0) !== (b.count > 0)) return b.count - a.count;
  if (a.count !== b.count) return b.count - a.count;
  return a.name.localeCompare(b.name, 'de');
});

const totalArticles = allArticles.length;
const totalSpecialties = SPECIALTIES.length;
const filledSpecialties = withCount.filter((s) => s.count > 0).length;
---

<Base
  title="Fachgebiete"
  description="Alle medizinischen Fachgebiete im Überblick — evidenzbasierte Patientenartikel zu jedem Thema."
>
  <section class="py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-5">
      <h1 class="text-3xl md:text-4xl font-bold text-text mb-3">Fachgebiete</h1>
      <p class="text-text-secondary mb-2 leading-relaxed">
        {totalArticles} evidenzbasierte Artikel in {filledSpecialties} von {totalSpecialties} Fachgebieten.
      </p>
      <p class="text-text-muted text-sm mb-10 leading-relaxed">
        Dein Fachgebiet ist noch leer? <a href="/frage-stellen" class="text-primary no-underline hover:underline font-medium">Stelle eine Frage</a> — wir prüfen jeden Vorschlag und schreiben den fehlenden Artikel.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {withCount.map((cat) => {
          const empty = cat.count === 0;
          return (
            <a
              href={`/fachgebiet/${cat.slug}`}
              class:list={[
                'group flex items-start justify-between gap-3 p-5 rounded-xl border bg-bg-card transition-all no-underline',
                empty
                  ? 'border-border-light hover:border-border opacity-70 hover:opacity-100'
                  : 'border-border hover:border-primary/30 hover:shadow-md',
              ]}
            >
              <div class="min-w-0">
                <h2 class={`text-lg font-bold transition-colors ${empty ? 'text-text-secondary group-hover:text-text' : 'text-text group-hover:text-primary'}`}>
                  {cat.name}
                </h2>
                <p class="text-xs text-text-muted mt-1 leading-snug">{cat.description}</p>
                <p class="text-sm font-medium mt-2">
                  {empty ? (
                    <span class="text-text-muted">Noch keine Artikel</span>
                  ) : (
                    <span class="text-primary">{cat.count} {cat.count === 1 ? 'Artikel' : 'Artikel'}</span>
                  )}
                </p>
              </div>
              <svg class={`w-5 h-5 flex-shrink-0 mt-1 transition-colors ${empty ? 'text-text-muted/60' : 'text-text-muted group-hover:text-primary'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</Base>
