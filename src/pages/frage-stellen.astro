---
import Base from '../layouts/Base.astro';
---

<Base
  title="Frage stellen"
  description="Stell deine medizinische Frage – wir prüfen sie und veröffentlichen einen evidenzbasierten Artikel."
>
  <section class="py-12 md:py-16">
    <div class="max-w-2xl mx-auto px-5">
      <div class="text-center mb-10">
        <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-text mb-3" style="font-family: var(--font-display);">
          Deine Frage zählt.
        </h1>
        <p class="text-lg text-text-secondary">
          Worüber willst du eine evidenzbasierte Antwort? Wir prüfen jede Frage und schreiben einen Artikel,
          wenn das Thema neu und medizinisch relevant ist.
        </p>
      </div>

      <form id="frage-form" class="bg-bg-card border border-border rounded-2xl p-6 md:p-8 space-y-5 shadow-sm">
        <div>
          <label for="question" class="block text-sm font-medium text-text mb-1.5">
            Deine Frage <span class="text-red-600">*</span>
          </label>
          <textarea
            id="question"
            name="question"
            rows="4"
            required
            minlength="10"
            maxlength="1000"
            placeholder="z.B. Helfen Magnesium-Präparate wirklich gegen Wadenkrämpfe?"
            class="w-full px-4 py-3 rounded-xl border border-border bg-white text-base text-text placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all"
          ></textarea>
          <div class="text-xs text-text-muted mt-1">10–1000 Zeichen. Möglichst konkret formulieren.</div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="first_name" class="block text-sm font-medium text-text mb-1.5">
              Vorname <span class="text-text-muted text-xs font-normal">(optional)</span>
            </label>
            <input
              id="first_name"
              name="first_name"
              type="text"
              maxlength="80"
              class="w-full px-4 py-2.5 rounded-xl border border-border bg-white text-base text-text focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-text mb-1.5">
              E-Mail <span class="text-red-600">*</span>
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              autocomplete="email"
              class="w-full px-4 py-2.5 rounded-xl border border-border bg-white text-base text-text focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all"
            />
          </div>
        </div>

        <!-- Honeypot: für Menschen versteckt, Bots füllen es oft aus -->
        <div class="absolute left-[-9999px]" aria-hidden="true">
          <label for="website">Website</label>
          <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
        </div>

        <div class="text-xs text-text-muted leading-relaxed border-t border-border-light pt-4">
          Mit dem Absenden stimmst du der Speicherung deiner Frage und E-Mail zu Bearbeitungs- und
          Antwortzwecken zu. Wir verwenden deine Daten nicht für Werbung und geben sie nicht an Dritte
          weiter. Details findest du in der <a href="/impressum" class="text-primary no-underline hover:underline">Datenschutzerklärung</a>.
          Pro E-Mail-Adresse sind 5 Fragen pro Woche möglich.
        </div>

        <button
          type="submit"
          id="submit-btn"
          class="w-full py-3.5 px-6 bg-primary text-white font-semibold rounded-xl hover:bg-primary-dark transition-colors text-base disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Frage einreichen
        </button>

        <div id="form-result" class="hidden"></div>
      </form>
    </div>
  </section>

  <script>
    const form = document.getElementById('frage-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const result = document.getElementById('form-result') as HTMLDivElement;

    function show(html: string, tone: 'success' | 'info' | 'error') {
      const palette = {
        success: 'bg-green-50 border-green-200 text-green-900',
        info:    'bg-blue-50 border-blue-200 text-blue-900',
        error:   'bg-red-50 border-red-200 text-red-900',
      }[tone];
      result.className = `mt-2 p-4 rounded-xl border ${palette} text-sm leading-relaxed`;
      result.innerHTML = html;
      result.classList.remove('hidden');
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = 'Wird geprüft …';
      result.classList.add('hidden');

      const fd = new FormData(form);
      const payload = {
        question: String(fd.get('question') || ''),
        email: String(fd.get('email') || ''),
        first_name: fd.get('first_name') ? String(fd.get('first_name')) : null,
        website: String(fd.get('website') || ''),
      };

      try {
        const r = await fetch('/api/fragen/submit', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await r.json();

        if (r.status === 429) {
          const reason = data.reason === 'ip_limit'
            ? 'Von dieser Internetverbindung wurden in den letzten 7 Tagen schon 5 Fragen gestellt.'
            : 'Mit dieser E-Mail wurden in den letzten 7 Tagen schon 5 Fragen gestellt.';
          show(`<strong>Limit erreicht.</strong><br/>${reason} Bitte versuche es nächste Woche wieder.`, 'error');
          submitBtn.disabled = false;
          submitBtn.textContent = 'Frage einreichen';
          return;
        }
        if (!r.ok) {
          show('Da ging etwas schief. Bitte versuche es in ein paar Minuten nochmal.', 'error');
          submitBtn.disabled = false;
          submitBtn.textContent = 'Frage einreichen';
          return;
        }

        if (data.status === 'duplicate') {
          show(
            `<strong>Diese Frage ist schon beantwortet.</strong><br/>` +
            `Lies dazu unseren Artikel: <a href="/artikel/${data.duplicate_slug}" class="underline font-semibold">${data.duplicate_title}</a>.`,
            'info'
          );
        } else if (data.status === 'rejected') {
          show(
            `<strong>Frage konnte nicht angenommen werden.</strong><br/>${data.reason || 'Bitte formuliere die Frage konkreter und medizinisch relevant.'}`,
            'error'
          );
        } else {
          show(
            `<strong>Danke!</strong><br/>` +
            `Deine Frage ist eingereicht. Falls wir daraus einen Artikel machen, melden wir uns per E-Mail.`,
            'success'
          );
          form.reset();
        }
      } catch (err) {
        show('Verbindungsfehler. Bitte später nochmal versuchen.', 'error');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Frage einreichen';
      }
    });
  </script>
</Base>
