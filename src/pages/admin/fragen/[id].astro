---
export const prerender = false;

import AuthLayout from '../../../layouts/AuthLayout.astro';
import { createSupabaseServerClient } from '../../../lib/supabase/server';

const user = Astro.locals.user!;
const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const id = Astro.params.id!;

let flash: string | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = String(form.get('action') || '');

  if (action === 'accept') {
    const title = String(form.get('topic_title') || '').trim();
    const description = String(form.get('topic_description') || '').trim() || null;
    if (title.length < 5) {
      flash = 'Topic-Titel muss mindestens 5 Zeichen haben.';
    } else {
      const { data: topicId, error } = await supabase.rpc('accept_patient_question', {
        p_question_id: id,
        p_actor_id: user.id,
        p_topic_title: title,
        p_topic_description: description,
      });
      if (error) flash = `Fehler: ${error.message}`;
      else return Astro.redirect(`/admin/topics/${topicId}?msg=created_from_question`);
    }
  } else if (action === 'reject') {
    const reason = String(form.get('rejection_reason') || '').trim() || 'Manuell abgelehnt';
    const { error } = await supabase
      .from('patient_questions')
      .update({ status: 'rejected', rejection_reason: reason })
      .eq('id', id);
    flash = error ? `Fehler: ${error.message}` : 'Frage abgelehnt.';
  } else if (action === 'mark_duplicate') {
    const slug = String(form.get('duplicate_slug') || '').trim();
    if (!slug) {
      flash = 'Bitte einen Artikel-Slug angeben.';
    } else {
      const { error } = await supabase
        .from('patient_questions')
        .update({ status: 'duplicate', duplicate_of_slug: slug })
        .eq('id', id);
      flash = error ? `Fehler: ${error.message}` : 'Als Duplikat markiert.';
    }
  }
}

const { data: question } = await supabase
  .from('patient_questions')
  .select('*')
  .eq('id', id)
  .maybeSingle();

if (!question) return Astro.redirect('/admin/fragen?error=not_found');

const ai = (question.ai_classification || {}) as any;
const suggestedTitle = ai.suggested_topic_title || '';
---

<AuthLayout title="Patientenfrage" section="admin" user={user}>
  <div class="space-y-6 max-w-3xl">
    <nav class="text-sm text-text-muted">
      <a href="/admin/fragen" class="hover:text-primary no-underline">Patientenfragen</a>
      <span class="mx-2">/</span><span>Detail</span>
    </nav>

    {flash && <div class="p-3 rounded-lg bg-blue-50 border border-blue-200 text-sm text-blue-900">{flash}</div>}

    <div class="bg-white rounded-2xl border border-border-light p-6 space-y-3">
      <div class="flex items-start justify-between gap-4">
        <h1 class="text-xl font-bold text-text">Eingereichte Frage</h1>
        <span class="text-xs font-semibold px-2 py-0.5 rounded bg-gray-100 text-gray-700">{question.status}</span>
      </div>
      <p class="text-text leading-relaxed">{question.question}</p>

      <dl class="grid grid-cols-2 gap-x-4 gap-y-2 text-sm pt-3 border-t border-border-light">
        <dt class="text-text-muted">E-Mail</dt><dd>{question.email}</dd>
        {question.first_name && (<><dt class="text-text-muted">Vorname</dt><dd>{question.first_name}</dd></>)}
        <dt class="text-text-muted">Eingereicht</dt><dd>{new Date(question.created_at).toLocaleString('de-DE')}</dd>
        {question.ip_address && (<><dt class="text-text-muted">IP</dt><dd class="font-mono text-xs">{question.ip_address}</dd></>)}
        <dt class="text-text-muted">Newsletter</dt><dd>{question.newsletter_consent ? 'ja' : 'nein'}</dd>
      </dl>
    </div>

    <div class="bg-white rounded-2xl border border-border-light p-6 space-y-2">
      <h2 class="text-lg font-bold text-text">KI-Bewertung (Haiku 4.5)</h2>
      <div class="grid grid-cols-2 gap-3 text-sm">
        <div><span class="text-text-muted">Sinnvoll:</span> <span class={ai.sensible ? 'text-green-700' : 'text-red-700'}>{ai.sensible ? 'ja' : 'nein'}</span></div>
        <div><span class="text-text-muted">Medizinisch relevant:</span> <span class={ai.medical_relevant ? 'text-green-700' : 'text-red-700'}>{ai.medical_relevant ? 'ja' : 'nein'}</span></div>
        {ai.duplicate_slug && <div class="col-span-2"><span class="text-text-muted">Duplikat-Vorschlag:</span> <a href={`/artikel/${ai.duplicate_slug}`} target="_blank" class="text-primary no-underline">{ai.duplicate_slug} ↗</a></div>}
        {suggestedTitle && <div class="col-span-2"><span class="text-text-muted">Vorgeschlagener Topic-Titel:</span> {suggestedTitle}</div>}
      </div>
      {question.ai_reasoning && <p class="text-sm text-text-secondary italic mt-2">„{question.ai_reasoning}"</p>}
    </div>

    {question.duplicate_of_slug && (
      <div class="bg-amber-50 rounded-2xl border border-amber-200 p-6 text-sm text-amber-900">
        Markiert als Duplikat von <a href={`/artikel/${question.duplicate_of_slug}`} target="_blank" class="font-semibold underline">{question.duplicate_of_slug}</a>.
      </div>
    )}

    {question.rejection_reason && (
      <div class="bg-red-50 rounded-2xl border border-red-200 p-6 text-sm text-red-900">
        <strong>Ablehnungsgrund:</strong> {question.rejection_reason}
      </div>
    )}

    {question.topic_id && (
      <div class="bg-green-50 rounded-2xl border border-green-200 p-6 text-sm text-green-900">
        Topic erstellt: <a href={`/admin/topics/${question.topic_id}`} class="font-semibold underline">{question.topic_id.slice(0, 8)}…</a>
      </div>
    )}

    {question.status === 'submitted' && (
      <>
        <div class="bg-white rounded-2xl border border-border-light p-6 space-y-3">
          <h2 class="text-lg font-bold text-text">Akzeptieren → in Pipeline</h2>
          <form method="post" class="space-y-3">
            <input type="hidden" name="action" value="accept" />
            <label class="block text-sm">
              <span class="block text-xs text-text-muted mb-1">Topic-Titel</span>
              <input type="text" name="topic_title" required minlength="5" value={suggestedTitle}
                class="w-full px-3 py-2 rounded border border-border-light text-sm bg-white" />
            </label>
            <label class="block text-sm">
              <span class="block text-xs text-text-muted mb-1">Beschreibung (optional, sonst wird Frage genommen)</span>
              <textarea name="topic_description" rows="2" placeholder={question.question}
                class="w-full px-3 py-2 rounded border border-border-light text-sm bg-white"></textarea>
            </label>
            <button type="submit" class="px-4 py-2 rounded bg-green-600 text-white text-sm font-medium hover:bg-green-700">
              Topic erstellen + Frage akzeptieren
            </button>
          </form>
        </div>

        <div class="bg-white rounded-2xl border border-border-light p-6 space-y-3">
          <h2 class="text-lg font-bold text-text">Als Duplikat markieren</h2>
          <form method="post" class="flex gap-2 items-end flex-wrap">
            <input type="hidden" name="action" value="mark_duplicate" />
            <label class="flex-1 text-sm">
              <span class="block text-xs text-text-muted mb-1">Artikel-Slug</span>
              <input type="text" name="duplicate_slug" required value={ai.duplicate_slug || ''}
                class="w-full px-3 py-2 rounded border border-border-light text-sm bg-white" />
            </label>
            <button type="submit" class="px-4 py-2 rounded bg-bg-subtle border border-border-light text-sm hover:bg-white">
              Markieren
            </button>
          </form>
        </div>

        <div class="bg-white rounded-2xl border border-border-light p-6 space-y-3">
          <h2 class="text-lg font-bold text-text">Ablehnen</h2>
          <form method="post" onsubmit="return confirm('Frage wirklich ablehnen?')" class="flex gap-2 items-end flex-wrap">
            <input type="hidden" name="action" value="reject" />
            <label class="flex-1 text-sm">
              <span class="block text-xs text-text-muted mb-1">Begründung (optional)</span>
              <input type="text" name="rejection_reason"
                class="w-full px-3 py-2 rounded border border-border-light text-sm bg-white" />
            </label>
            <button type="submit" class="px-4 py-2 rounded text-sm text-red-600 hover:text-red-800">
              Ablehnen
            </button>
          </form>
        </div>
      </>
    )}
  </div>
</AuthLayout>
