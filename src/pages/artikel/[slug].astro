---
import Base from '../../layouts/Base.astro';
import ReviewerBadge from '../../components/ReviewerBadge.astro';
import { getCollection, render } from 'astro:content';
import {
  buildMedicalWebPage,
  buildArticle,
  buildBreadcrumb,
  buildFaqPage,
  PUBLISHER_ORG_SCHEMA,
  BRAND_ORG_SCHEMA,
  SITE_URL,
} from '../../lib/schema';
import { specialtySlug } from '../../lib/specialties';

export async function getStaticPaths() {
  const articles = await getCollection('artikel', ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.data.slug },
    props: { article, allArticles: articles },
  }));
}

const { article, allArticles } = Astro.props;
const { Content } = await render(article);

const formattedDate = new Date(article.data.date).toLocaleDateString('de-DE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

// Estimate reading time (~200 words/min German)
const wordCount = article.body ? article.body.split(/\s+/).length : 0;
const readingTime = Math.max(5, Math.ceil(wordCount / 200));

// Category-Slug aus dem Whitelist-Helper — eine einzige Quelle der Wahrheit
const catSlug = specialtySlug(article.data.category);

// Related-Articles-Score: gewichtete Summe aus
//   α · Tag-Jaccard + β · Keyword-Token-Jaccard + γ · Kategorie-Match
// Defaults aus Plan: 0.5 / 0.4 / 0.1.
const RELATED_ALPHA = 0.5;
const RELATED_BETA = 0.4;
const RELATED_GAMMA = 0.1;
const RELATED_MIN = 3;
const RELATED_MAX = 5;

function jaccardSets(a: Set<string>, b: Set<string>): number {
  if (a.size === 0 || b.size === 0) return 0;
  let inter = 0;
  for (const t of a) if (b.has(t)) inter++;
  const union = a.size + b.size - inter;
  return union === 0 ? 0 : inter / union;
}

function tagSet(data: any): Set<string> {
  return new Set((data.tags ?? []).map((t: string) => t.toLowerCase().trim()));
}

// mainKeyword + secondaryKeywords werden tokenisiert, Stop-Tokens kürzer als
// 3 Zeichen werden weggelassen.
function keywordTokenSet(data: any): Set<string> {
  const out = new Set<string>();
  const all: string[] = [
    data.mainKeyword,
    ...(data.secondaryKeywords ?? []),
  ].filter(Boolean);
  for (const kw of all) {
    for (const tok of kw.toLowerCase().split(/[\s\-_/,]+/)) {
      if (tok.length >= 3) out.add(tok);
    }
  }
  return out;
}

function relatednessScore(self: any, other: any): number {
  const tag = jaccardSets(tagSet(self), tagSet(other));
  const kw = jaccardSets(keywordTokenSet(self), keywordTokenSet(other));
  const cat = self.category === other.category ? 1 : 0;
  return RELATED_ALPHA * tag + RELATED_BETA * kw + RELATED_GAMMA * cat;
}

const scored = allArticles
  .filter((a) => a.data.slug !== article.data.slug)
  .map((a) => ({ article: a, score: relatednessScore(article.data, a.data) }))
  .filter((s) => s.score > 0)
  .sort((a, b) => b.score - a.score);

// Bis zu RELATED_MAX nehmen; wenn weniger als RELATED_MIN → mit den
// jüngsten Artikeln derselben Kategorie auffüllen.
const picked = [...scored.slice(0, RELATED_MAX)];
if (picked.length < RELATED_MIN) {
  const seen = new Set(picked.map((s) => s.article.data.slug));
  const fillers = allArticles
    .filter((a) =>
      a.data.slug !== article.data.slug &&
      a.data.category === article.data.category &&
      !seen.has(a.data.slug)
    )
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
  for (const f of fillers) {
    picked.push({ article: f, score: 0 });
    if (picked.length >= RELATED_MIN) break;
  }
}

const relatedArticles = picked.map((s) => s.article);

const allFromCategory = picked.every((s) => s.score === 0);
const relatedHeading = allFromCategory && relatedArticles.length > 0
  ? `Weitere Artikel aus ${article.data.category}`
  : 'Verwandte Artikel';

// Canonical URL — siteUrl als Single Source of Truth aus lib/schema
const canonicalUrl = `${SITE_URL}/artikel/${article.data.slug}/`;

// Extract FAQ pairs from article body (section with "Fragen" or "fragen" in heading)
function extractFaq(body: string): Array<{ question: string; answer: string }> {
  if (!body) return [];
  // Find the Q&A heading (## or ### with Fragen/fragen)
  const headingMatch = body.match(/^#{2,3}[^\n]*[Ff]ragen[^\n]*$/m);
  if (!headingMatch || headingMatch.index === undefined) return [];
  // Content starts after the heading, ends at next ## heading
  const afterHeading = body.slice(headingMatch.index + headingMatch[0].length);
  const endMatch = afterHeading.match(/\n## /);
  const section = endMatch ? afterHeading.slice(0, endMatch.index) : afterHeading;

  const faqs: Array<{ question: string; answer: string }> = [];
  // Match pattern: - **"Question"** (allow leading whitespace, various quote styles, and optional trailing *)
  // Capture until next question or heading
  const qaRegex = /^\s*- \*\*[„"']?([^\n*]+?)[""'"]?\*\*?\s*(?:\n|\s*—\s*|\s+)([^\n][^\n]*(?:\n(?!\s*- \*\*|^#{1,3} )[^\n]*)*)/gm;
  let m;
  while ((m = qaRegex.exec(section)) !== null) {
    let question = m[1].trim().replace(/[*"'„"]+$/, '').trim();
    // Ensure question ends with ?
    if (!question.endsWith('?')) question = question + '?';
    const answer = m[2].trim().replace(/^[—\-\s]+/, '').trim();
    if (question && answer && answer.length > 15 && question.length > 5) {
      faqs.push({ question, answer });
    }
  }
  return faqs;
}

// FAQ-Quelle: Vorzug für strukturierte `faqItems` aus dem Frontmatter,
// Fallback auf Regex-Extraktion aus dem Body.
const faqs = (article.data.faqItems && article.data.faqItems.length >= 2)
  ? article.data.faqItems
  : extractFaq(article.body || '');

// JSON-LD-Schemas via Helper-Modul.
const articleData = {
  title: article.data.title,
  slug: article.data.slug,
  date: article.data.date,
  category: article.data.category,
  excerpt: article.data.excerpt,
  image: article.data.image,
  tags: article.data.tags,
  mainKeyword: article.data.mainKeyword,
  secondaryKeywords: article.data.secondaryKeywords,
  reviewer: article.data.reviewer,
};

const medicalWebPageJsonLd = buildMedicalWebPage(articleData, canonicalUrl);
const articleJsonLd = buildArticle(articleData, canonicalUrl);
const breadcrumbJsonLd = buildBreadcrumb(articleData, canonicalUrl, catSlug);
const faqJsonLd = buildFaqPage(faqs);
---

<Base
  title={article.data.seoTitle || article.data.title}
  description={article.data.seoDescription || article.data.excerpt}
  image={article.data.image}
  canonical={canonicalUrl}
  ogType="article"
  noBrandSuffix={true}
  publishedTime={article.data.date}
  modifiedTime={article.data.date}
  articleSection={article.data.category}
  articleTags={article.data.tags}
>
  <script type="application/ld+json" set:html={JSON.stringify(medicalWebPageJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  {faqJsonLd && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}
  <script type="application/ld+json" set:html={JSON.stringify(PUBLISHER_ORG_SCHEMA)} />
  <script type="application/ld+json" set:html={JSON.stringify(BRAND_ORG_SCHEMA)} />

  <article>
    <!-- Hero Image -->
    {article.data.image && (
      <div class="w-full max-w-4xl mx-auto px-5 pt-8 md:pt-12">
        <img
          src={article.data.image}
          alt={article.data.title}
          class="w-full h-auto rounded-2xl object-cover shadow-sm"
          loading="eager"
        />
      </div>
    )}

    <div class="article-bg">
    <div class="max-w-3xl mx-auto px-5 pt-8 pb-16">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="mb-6 text-sm text-text-muted">
        <ol class="flex items-center flex-wrap gap-1.5">
          <li><a href="/" class="hover:text-primary no-underline">Startseite</a></li>
          <li aria-hidden="true" class="text-border">/</li>
          <li><a href={`/fachgebiet/${catSlug}`} class="hover:text-primary no-underline">{article.data.category}</a></li>
          <li aria-hidden="true" class="text-border">/</li>
          <li class="text-text truncate" aria-current="page">{article.data.title}</li>
        </ol>
      </nav>

      <!-- Category Badge -->
      <div class="text-center mb-4">
        <a href={`/fachgebiet/${catSlug}`}
           class="inline-block px-3 py-1 rounded-full bg-primary/10 text-primary font-semibold text-xs uppercase tracking-wider no-underline hover:bg-primary/20 transition-colors">
          {article.data.category}
        </a>
      </div>

      <!-- Title -->
      <h1 class="text-3xl md:text-[2.5rem] font-bold text-text leading-tight text-center mb-6">
        {article.data.title}
      </h1>

      <!-- Meta Line -->
      <p class="text-center text-sm text-text-muted mb-8">
        Zuletzt aktualisiert: {formattedDate} · Lesezeit: ca. {readingTime} Minuten · Evidenzcheck: Geprüft anhand aktueller Meta-Analysen und Leitlinien
      </p>

      <!-- Reviewer-Box: Live-Status aus Supabase via Server Island -->
      <ReviewerBadge server:defer slug={article.data.slug} variant="full">
        <div slot="fallback" class="mb-10 p-5 md:p-6 rounded-2xl border border-border-light bg-white shadow-sm animate-pulse">
          <div class="flex items-start gap-4">
            <div class="w-16 h-16 rounded-full bg-gray-200 flex-shrink-0"></div>
            <div class="flex-1 min-w-0 space-y-2">
              <div class="h-4 bg-gray-200 rounded w-48"></div>
              <div class="h-3 bg-gray-200 rounded w-64"></div>
              <div class="h-3 bg-gray-200 rounded w-40"></div>
            </div>
          </div>
        </div>
      </ReviewerBadge>

      <!-- Die Kernaussage kommt jetzt aus dem Markdown-Inhalt mit class="kernaussage" -->

      <!-- Artikel-Inhalt -->
      <div class="article-content prose prose-gray max-w-none
        prose-headings:text-text prose-headings:font-bold
        prose-h2:text-[1.6rem] prose-h2:mt-12 prose-h2:mb-5 prose-h2:leading-snug
        prose-h3:text-xl prose-h3:mt-9 prose-h3:mb-3 prose-h3:font-semibold
        prose-p:text-text-secondary prose-p:leading-[1.8] prose-p:text-[1.05rem] prose-p:mb-5
        prose-a:text-primary prose-a:no-underline hover:prose-a:underline
        prose-strong:text-text prose-strong:font-semibold
        prose-li:text-text-secondary prose-li:leading-[1.8] prose-li:text-[1.05rem]
        prose-blockquote:border-primary prose-blockquote:bg-sky-50/50 prose-blockquote:rounded-r-xl prose-blockquote:py-2 prose-blockquote:px-5 prose-blockquote:text-text-secondary prose-blockquote:not-italic
        prose-table:text-sm
        prose-th:text-text prose-th:font-semibold prose-th:bg-gray-50 prose-th:p-3
        prose-td:text-text-secondary prose-td:p-3
        prose-img:rounded-xl prose-img:shadow-sm
      ">
        <Content />
      </div>

      <!-- Quellen zuerst, danach Verifikations-Prompt am Schluss -->
      {article.data.sources && article.data.sources.length > 0 && (
        <div class="mt-12 border-t border-border-light pt-8">
          <h2 class="text-lg font-bold text-text mb-4">Quellen</h2>
          <ol class="space-y-3 text-sm text-text-secondary list-decimal list-outside ml-5">
            {article.data.sources.map((source) => {
              if (typeof source === 'string') {
                return <li class="leading-relaxed">{source}</li>;
              }
              const link = source.doi ? `https://doi.org/${source.doi}` : source.url ?? null;
              const cite = [
                source.authors,
                source.journal && (source.year ? `${source.journal} ${source.year}` : source.journal),
                !source.journal && source.year ? String(source.year) : null,
                source.n ? `n=${source.n.toLocaleString('de-DE')}` : null,
              ].filter(Boolean).join(' · ');
              return (
                <li class="leading-relaxed">
                  <div class="font-medium text-text">
                    {link ? (
                      <a href={link} target="_blank" rel="noopener noreferrer" class="text-primary no-underline hover:underline">
                        {source.title ?? link}
                      </a>
                    ) : (source.title ?? source.id ?? '—')}
                    {source.quality === 'high' && (
                      <span class="ml-2 inline-block text-[10px] uppercase tracking-wider px-1.5 py-0.5 rounded bg-green-50 text-green-700 font-semibold">hohe Evidenz</span>
                    )}
                  </div>
                  {cite && <div class="text-xs text-text-muted mt-0.5">{cite}</div>}
                  {source.key_finding_de && (
                    <div class="text-xs text-text-secondary mt-1 italic">{source.key_finding_de}</div>
                  )}
                </li>
              );
            })}
          </ol>
        </div>
      )}

      <!-- Verifikations-Prompt: Leser kann den Artikel mit jeder KI nachprüfen -->
      {article.data.prompt && (
        <section class="mt-14 border border-border-light rounded-2xl overflow-hidden bg-white">
          <header class="px-6 py-5 bg-bg-subtle border-b border-border-light">
            <h2 class="text-lg font-bold text-text">Diesen Artikel selbst überprüfen</h2>
            <p class="text-sm text-text-secondary mt-1.5 leading-relaxed">
              Kopiere den folgenden Prompt in ChatGPT, Claude oder eine andere KI deiner Wahl.
              Du bekommst eine unabhängige Zweitmeinung, die du mit diesem Artikel vergleichen kannst.
            </p>
          </header>
          <div class="relative">
            <button
              type="button"
              data-copy-target="article-verify-prompt"
              class="copy-prompt-btn absolute top-3 right-3 px-3 py-1.5 text-xs font-medium bg-white border border-border-light rounded-lg hover:bg-bg-subtle transition-colors"
            >
              Prompt kopieren
            </button>
            <pre id="article-verify-prompt" class="px-6 py-5 pr-32 text-sm text-text-secondary whitespace-pre-wrap font-mono leading-relaxed overflow-x-auto m-0">{article.data.prompt}</pre>
          </div>
        </section>
      )}
      <script is:inline>
        document.querySelectorAll('.copy-prompt-btn').forEach((btn) => {
          btn.addEventListener('click', async () => {
            const id = btn.getAttribute('data-copy-target');
            const el = id ? document.getElementById(id) : null;
            const text = el ? el.textContent || '' : '';
            try {
              await navigator.clipboard.writeText(text);
              const original = btn.textContent;
              btn.textContent = 'Kopiert ✓';
              setTimeout(() => { btn.textContent = original; }, 1500);
            } catch (e) {}
          });
        });
      </script>

      <!-- Ähnliche Artikel -->
      {relatedArticles.length > 0 && (
        <div class="mt-14 pt-8 border-t border-border-light">
          <h2 class="text-lg font-bold text-text mb-5">{relatedHeading}</h2>
          <div class="grid gap-3">
            {relatedArticles.map((rel) => (
              <a href={`/artikel/${rel.data.slug}`}
                 class="group flex items-start gap-4 p-4 rounded-xl border border-border-light hover:border-primary/40 hover:bg-bg-subtle transition-all no-underline">
                {rel.data.image && (
                  <img src={rel.data.image} alt={rel.data.title} loading="lazy"
                       class="w-20 h-20 rounded-lg object-cover flex-shrink-0" />
                )}
                <div class="flex-1 min-w-0">
                  <h3 class="font-semibold text-text group-hover:text-primary transition-colors leading-snug mb-1">
                    {rel.data.title}
                  </h3>
                  <p class="text-sm text-text-muted line-clamp-2">{rel.data.excerpt}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Zurück -->
      <div class="mt-14 pt-8 border-t border-border-light">
        <a href="/" class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-primary-dark transition-colors no-underline">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Zurück zur Übersicht
        </a>
      </div>
    </div>
    </div>
  </article>
</Base>
