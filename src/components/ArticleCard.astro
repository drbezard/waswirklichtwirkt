---
interface Props {
  title: string;
  slug: string;
  date: string;
  category: string;
  excerpt: string;
  reviewed: boolean;
  reviewer?: string;
  reviewerPhoto?: string;
  image?: string;
}

const { title, slug, date, category, excerpt, reviewed, reviewer, reviewerPhoto, image } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('de-DE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const reviewLabel = reviewed ? 'Geprüft' : 'Ausstehend – wartet auf Arzt-Review';
---

<article class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100">
  <!-- Hero Image (full width, top) -->
  {image && (
    <a href={`/artikel/${slug}`} class="block overflow-hidden">
      <img
        src={image}
        alt={title}
        class="w-full h-52 sm:h-60 object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    </a>
  )}

  <!-- Content -->
  <div class="p-5 sm:p-6">
    <!-- Meta Row: Category + Date + Review Status -->
    <div class="flex items-center gap-2 mb-3 text-sm flex-wrap">
      <span class="inline-block px-2.5 py-0.5 rounded-full bg-blue-50 text-blue-700 font-semibold text-xs uppercase tracking-wide border border-blue-100">
        {category}
      </span>
      <span class="text-gray-400 text-xs">{formattedDate}</span>
      <span class={`text-xs ml-auto ${reviewed ? 'text-green-600' : 'text-orange-500'}`}>
        {reviewLabel}
      </span>
    </div>

    <!-- Title -->
    <a href={`/artikel/${slug}`} class="no-underline block mb-2">
      <h3 class="text-xl sm:text-2xl font-bold text-gray-900 group-hover:text-blue-600 transition-colors leading-snug">
        {title}
      </h3>
    </a>

    <!-- Excerpt -->
    <p class="text-gray-600 text-sm sm:text-base leading-relaxed mb-5">{excerpt}</p>

    <!-- Review Status Box -->
    <div class={`flex items-center gap-3 p-3 rounded-xl mb-4 ${reviewed ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-gray-100'}`}>
      {reviewed ? (
        <>
          {reviewerPhoto ? (
            <img src={reviewerPhoto} alt={reviewer || ''} class="w-10 h-10 rounded-full object-cover border-2 border-green-200 flex-shrink-0" />
          ) : (
            <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
          )}
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm font-semibold text-green-800">
                Geprüft von {reviewer || 'Facharzt'}
              </span>
            </div>
            <span class="text-xs text-green-600">Fachärztlich geprüft und freigegeben</span>
          </div>
          <span class="text-xs font-bold text-green-700 bg-green-100 px-2.5 py-1 rounded-full flex-shrink-0">
            Geprüft
          </span>
        </>
      ) : (
        <>
          <div class="w-10 h-10 rounded-full bg-amber-50 flex items-center justify-center flex-shrink-0 border border-amber-200">
            <span class="text-amber-500 font-bold text-lg">?</span>
          </div>
          <div class="flex-1 min-w-0">
            <span class="text-sm font-medium text-gray-700">Noch kein Arzt-Review</span>
            <span class="block text-xs text-gray-500">Artikel wartet auf Fachprüfung</span>
          </div>
          <span class="text-xs font-bold text-orange-600 bg-orange-50 px-2.5 py-1 rounded-full flex-shrink-0 border border-orange-200">
            Ausstehend
          </span>
        </>
      )}
    </div>

    <!-- Read Link -->
    <a href={`/artikel/${slug}`} class="inline-flex items-center gap-1.5 text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors no-underline group/link">
      Artikel lesen
      <svg class="w-4 h-4 group-hover/link:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</article>
