---
interface Props {
  title: string;
  slug: string;
  date: string;
  category: string;
  excerpt: string;
  reviewed: boolean;
  reviewer?: string;
  reviewerPhoto?: string;
  image?: string;
}

const { title, slug, date, category, excerpt, reviewed, reviewer, reviewerPhoto, image } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('de-DE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<article class="group border border-border-light rounded-2xl overflow-hidden hover:shadow-lg hover:border-border/60 transition-all duration-300 bg-bg-card">
  <!-- Image + Content Row -->
  <div class="flex flex-col md:flex-row">
    <!-- Image -->
    {image && (
      <a href={`/artikel/${slug}`} class="block md:w-64 lg:w-72 flex-shrink-0 overflow-hidden">
        <img
          src={image}
          alt={title}
          class="w-full h-48 md:h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      </a>
    )}

    <!-- Content -->
    <div class="flex-1 p-5 md:p-6 flex flex-col justify-between min-w-0">
      <div>
        <!-- Meta Row -->
        <div class="flex items-center gap-2.5 mb-3 text-sm flex-wrap">
          <span class="inline-block px-2.5 py-0.5 rounded-full bg-primary/10 text-primary font-semibold text-xs uppercase tracking-wide">
            {category}
          </span>
          <span class="text-text-muted text-xs">{formattedDate}</span>
        </div>

        <!-- Title -->
        <a href={`/artikel/${slug}`} class="no-underline block">
          <h3 class="text-lg md:text-xl font-bold text-text group-hover:text-primary transition-colors mb-2 leading-snug">
            {title}
          </h3>
        </a>

        <!-- Excerpt -->
        <p class="text-text-secondary text-sm leading-relaxed mb-4 line-clamp-2">{excerpt}</p>
      </div>

      <!-- Footer: Review Status + Link -->
      <div class="flex items-center justify-between pt-3 border-t border-border-light">
        <div class="flex items-center gap-2">
          {reviewed ? (
            <div class="flex items-center gap-2">
              {reviewerPhoto && (
                <img src={reviewerPhoto} alt={reviewer || ''} class="w-7 h-7 rounded-full object-cover" />
              )}
              <div class="flex items-center gap-1.5">
                <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-xs font-medium text-green-700">
                  Geprüft{reviewer ? ` von ${reviewer}` : ''}
                </span>
              </div>
            </div>
          ) : (
            <span class="flex items-center gap-1.5 text-xs text-text-muted">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Wartet auf Fachprüfung
            </span>
          )}
        </div>
        <a href={`/artikel/${slug}`} class="text-sm font-medium text-primary hover:text-primary-dark transition-colors no-underline flex items-center gap-1">
          Lesen
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</article>
