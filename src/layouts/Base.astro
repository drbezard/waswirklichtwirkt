---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  // OG-Typ. 'article' für Detail-Seiten, sonst Default 'website'.
  ogType?: 'website' | 'article';
  // Wenn true → kein "| Was Wirkt Wirklich"-Suffix im <title>.
  // Für Artikel-Routen, wo Keyword-Zeichen wertvoller sind als Brand-Building.
  noBrandSuffix?: boolean;
  // Article-spezifische OG-Felder (nur für ogType='article' relevant).
  publishedTime?: string;
  modifiedTime?: string;
  articleSection?: string;
  articleTags?: string[];
}

const {
  title,
  description = 'Keine Meinungen. Nur was die Wissenschaft belegt.',
  canonical,
  image,
  ogType = 'website',
  noBrandSuffix = false,
  publishedTime,
  modifiedTime,
  articleSection,
  articleTags,
} = Astro.props;

const siteTitle = 'Was Wirkt Wirklich';
const siteUrl = 'https://waswirktwirklich.com';

// Title-Logik:
// - noBrandSuffix=true (Artikel): nur der reine Titel, kein Brand-Suffix
// - title === siteTitle (selten — falls jemand nur "Was Wirkt Wirklich" passt):
//   "Was Wirkt Wirklich – <description>"
// - title beginnt bereits mit siteTitle (z.B. Homepage „Was Wirkt Wirklich – …"):
//   wird so übernommen, kein doppeltes Branding
// - sonst (statische Seiten wie /fachgebiete, /impressum): "<title> | Was Wirkt Wirklich"
const fullTitle = noBrandSuffix
  ? title
  : title === siteTitle
    ? `${siteTitle} – ${description}`
    : title.startsWith(siteTitle)
      ? title
      : `${title} | ${siteTitle}`;

// og:url fällt auf die Site-Wurzel zurück, wenn kein Canonical übergeben wurde
const ogUrl = canonical || siteUrl;

// Hreflang verweist auf den Canonical bzw. die Site-Wurzel
const hrefForLang = canonical || siteUrl;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Hreflang: Site ist deutschsprachig -->
    <link rel="alternate" hreflang="de-DE" href={hrefForLang} />
    <link rel="alternate" hreflang="x-default" href={hrefForLang} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:locale" content="de_DE" />
    {image && <meta property="og:image" content={image} />}
    {ogType === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {ogType === 'article' && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}
    {ogType === 'article' && articleSection && (
      <meta property="article:section" content={articleSection} />
    )}
    {ogType === 'article' && articleTags && articleTags.map((t) => (
      <meta property="article:tag" content={t} />
    ))}

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={image} />}

    <meta name="robots" content="index, follow" />
    <link rel="alternate" type="application/rss+xml" title="Was Wirkt Wirklich" href="/rss.xml" />
  </head>
  <body class="min-h-screen flex flex-col bg-bg">
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-lg border-b border-border-light">
      <div class="max-w-4xl mx-auto px-5 h-14 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 no-underline">
          <span class="text-lg font-bold tracking-tight text-text">Was Wirkt Wirklich</span>
        </a>
        <nav class="flex items-center gap-3 sm:gap-5">
          <a href="/fachgebiete" class="text-sm font-medium text-text-secondary hover:text-primary transition-colors no-underline">
            Fachgebiete
          </a>
          <a href="/frage-stellen" class="text-sm font-semibold text-white bg-primary hover:bg-primary-dark transition-colors no-underline px-3 py-1.5 rounded-lg">
            Frage stellen
          </a>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-border-light mt-20">
      <div class="max-w-4xl mx-auto px-5 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-text-muted">
        <span>Erstellt: April 2026 · Betreiber: Bezard Media GmbH</span>
        <a href="/impressum" class="hover:text-primary transition-colors no-underline">Impressum</a>
      </div>
    </footer>
  </body>
</html>
